rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper for Products
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() <= 100 &&
             data.category is string &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             data.status in ['Em Estoque', 'Estoque Baixo', 'Esgotado'];
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && isValidProduct(incoming());
      allow delete: if isSignedIn();
    }

    // Helper for Customers
    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 5 &&
             data.status in ['Ativo', 'Inativo'] &&
             data.totalSpent is number && data.totalSpent >= 0;
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomer(incoming());
      allow update: if isSignedIn() && isValidCustomer(incoming());
      allow delete: if isSignedIn();
    }

    // Helper for Transactions
    function isValidTransaction(data) {
      return data.client is string &&
             data.product is string &&
             data.value is number && data.value >= 0 &&
             data.status in ['Finalizada', 'Pendente', 'Cancelada'];
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidTransaction(incoming());
      allow delete: if isSignedIn();
    }
  }
}
